// ============================================================
// Jenkinsfile — CI/CD Pipeline with Docker
// ============================================================

pipeline {
    agent any

    // ── Environment Variables ─────────────────────────────
    environment {
        APP_NAME     = 'devops-app'
        IMAGE_NAME   = "myrepo/${APP_NAME}"
        IMAGE_TAG    = "${BUILD_NUMBER}"
        REGISTRY_URL = 'https://index.docker.io/v1/'
    }

    // ── Build Options ────────────────────────────────────
    options {
        timestamps()                          // Add timestamps to logs
        timeout(time: 30, unit: 'MINUTES')   // Fail if pipeline takes > 30 min
        disableConcurrentBuilds()            // Prevent parallel builds
    }

    // ── Pipeline Stages ──────────────────────────────────
    stages {

        stage('📥 Checkout') {
            steps {
                echo "Checking out source code..."
                checkout scm
                sh 'git log --oneline -5'
            }
        }

        stage('🔍 Code Quality') {
            steps {
                echo "Running linter..."
                sh '''
                    echo "Lint check complete"
                    # Example: pylint app/ --exit-zero
                '''
            }
        }

        stage('🏗️ Build Docker Image') {
            steps {
                echo "Building Docker image: ${IMAGE_NAME}:${IMAGE_TAG}"
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                sh "docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest"
            }
        }

        stage('🧪 Run Tests') {
            steps {
                echo "Running tests inside Docker container..."
                sh """
                    docker run --rm \
                        --name test-container \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        sh -c 'echo Tests passed'
                """
            }
        }

        stage('🚀 Push to Registry') {
            when {
                branch 'main'   // Only push from main branch
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${IMAGE_NAME}:latest
                        docker logout
                    '''
                }
            }
        }

        stage('🌐 Deploy to Staging') {
            when {
                branch 'main'
            }
            steps {
                echo "Deploying ${APP_NAME}:${IMAGE_TAG} to staging..."
                sh '''
                    docker stop ${APP_NAME} || true
                    docker rm   ${APP_NAME} || true
                    docker run -d \
                        --name ${APP_NAME} \
                        --restart always \
                        -p 5000:5000 \
                        ${IMAGE_NAME}:${IMAGE_TAG}
                    echo "Deployment complete"
                '''
            }
        }
    }

    // ── Post Actions ─────────────────────────────────────
    post {
        success {
            echo "✅ Pipeline succeeded! Build #${BUILD_NUMBER} deployed."
        }
        failure {
            echo "❌ Pipeline failed at build #${BUILD_NUMBER}. Check logs."
        }
        always {
            echo "🧹 Cleaning up dangling Docker images..."
            sh 'docker image prune -f || true'
        }
    }
}
